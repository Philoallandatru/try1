{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Concept Cards",
  "type": "object",
  "required": [
    "cards"
  ],
  "properties": {
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "card_id",
          "label",
          "category",
          "summary",
          "evidence"
        ],
        "properties": {
          "card_id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "terminology",
              "module",
              "interface",
              "risk",
              "rule"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "document",
                "evidence_span"
              ],
              "properties": {
                "document": {
                  "type": "string",
                  "minLength": 1
                },
                "version": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "page": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "section": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "evidence_span": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
