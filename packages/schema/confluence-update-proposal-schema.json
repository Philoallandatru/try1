{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Confluence Update Proposal",
  "type": "object",
  "required": [
    "proposal_id",
    "source_issue_key",
    "candidate_pages",
    "knowledge_action",
    "proposed_delta",
    "supporting_evidence",
    "confidence",
    "open_questions",
    "status",
    "version"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "source_issue_key": {
      "type": "string",
      "minLength": 1
    },
    "candidate_pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "page_id",
          "title"
        ],
        "properties": {
          "page_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "space_key": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "knowledge_action": {
      "type": "string",
      "enum": [
        "add",
        "revise",
        "append",
        "no_change"
      ]
    },
    "proposed_delta": {
      "type": "string",
      "minLength": 1
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "document",
          "version",
          "evidence_span"
        ],
        "properties": {
          "document": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "page": {
            "type": [
              "integer",
              "null"
            ]
          },
          "section": {
            "type": [
              "string",
              "null"
            ]
          },
          "clause": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_span": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "accepted",
        "rejected"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
